# ============================================================
# CallCentrix — все настройки подключений
# Скопировать рядом с бинарником и запустить:
#   export $(cat .env | xargs) && ./callcentrix
# или использовать docker-compose / systemd EnvironmentFile
# ============================================================

# ── HTTP сервер ──────────────────────────────────────────────
HTTP_ADDR=:8080
HTTP_PUBLIC_BASE=http://localhost:8080

# ── База данных PostgreSQL ───────────────────────────────────
DB_DSN=postgres://postgres:postgres@172.20.40.2:5432/postgres?sslmode=disable

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING
JWT_TTL_MINUTES=60

# ── Asterisk AMI ─────────────────────────────────────────────
AMI_ADDR=172.20.40.3:5038
AMI_USER=asterisk
AMI_PASS=asterisk

# ── Asterisk Recordings (nginx) ──────────────────────────────
ASTERISK_RECORDING_URL=http://172.20.40.3:8090/recordings